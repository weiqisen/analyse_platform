# ============================================================
#  生产环境配置模板 —— 复制成 .env 后逐项填写：  cp .env.example .env
#  标 <生成强口令> 的必须改，留空会导致 compose 启动直接报错（这是故意的）。
#  生成强口令：  openssl rand -base64 24
# ============================================================

# ===== 数据库（容器内自建 MySQL 的 root 口令，我方设定，设强）=====
DB_NAME=analyse_platform
DB_PASSWORD=<生成强口令>

# ===== RabbitMQ（容器内自建，我方设定，设强）=====
# 重要：CubeStudio 也要用这套账号连 MQ，两边必须一致——改这里就同步告知对方。
MQ_USER=defect_mq
MQ_PASS=<生成强口令>

# ===== 平台管理员初始口令 =====
# 仅在【空库首次启动】时用于建 admin 账号；若用 65 的数据 dump（users 表已有 admin），
# 本项不生效，请登录后到「用户管理」改口令。设了本项则不再建演示账号 zhangsan。
ADMIN_PASSWORD=<生成强口令>

# ===== 外部服务（现场已有 / 另一台机器，填现场地址）=====
CS_URL=
WORKFLOW_URL=http://10.10.52.127
SAMPLE_BUCKET=defect-samples

# ===== 工控机 SFTP 采集账号 =====
# 注意：这是【连现场工控机】用的账号，口令由那些工控机决定，不是我方能自定义的强口令。
# 现场若只用 MinIO 数据源、没有工控机，可留空。
WS_USER=root
WS_PASS=

# ===== 端口（按需改，非机密）=====
APP_PUBLISH_PORT=9573
MQ_PUBLISH_PORT=5672
MQ_MGMT_PORT=15672

# ===== MinIO（现场已有对象存储）=====
# 地址不走环境变量，存在数据库 storage_config，随 dump 迁过来，或登录后在
# 「基础配置 → 采集配置 → 数据源」维护。MinIO 的 AccessKey/SecretKey 也在那里配，
# 生产请用现场 MinIO 上单独创建的强密钥，别用 minioadmin/minioadmin123。
