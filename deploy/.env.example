# 复制成 .env 后按现场改：  cp .env.example .env
# 改完 CS_URL / WORKFLOW_URL 指向现场 CubeStudio；MinIO 地址不在这里（见下）。

# ===== 端口发布（宿主机:容器）=====
APP_PUBLISH_PORT=9573
DB_PUBLISH_PORT=3307
MQ_PUBLISH_PORT=5672
MQ_MGMT_PORT=15672

# ===== 数据库（容器内自建，无需现场提供）=====
DB_NAME=analyse_platform
DB_PASSWORD=123456

# ===== RabbitMQ（容器内自建）=====
# 注意：CubeStudio 也要连这个 MQ，账号密码要和对方约定一致。
MQ_USER=admin
MQ_PASS=Hlxd@123456

# ===== 外部服务（现场已有 / 另一台机器，填现场 IP）=====
CS_URL=
WORKFLOW_URL=http://10.10.52.127
SAMPLE_BUCKET=defect-samples

# ===== 工控机 SFTP 采集账号（图片采集用）=====
WS_USER=root
WS_PASS=hlxd@123

# ===== MinIO（现场已有对象存储）=====
# 地址不走环境变量，而是存在数据库 storage_config 里、在「基础配置 → 采集配置 → 数据源」
# 里维护。随 10-data.sql 一起迁过来即可；若现场 MinIO IP 不同，登录后到该页面改一下。
